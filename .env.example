# Copy this file to .env and fill in your values

# PostgreSQL connection (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nagatha_ai
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=nagatha_ai

# Ollama server URL (optional — defaults to http://localhost:11434)
# Change this if Ollama runs on a different machine or port
OLLAMA_URL=http://localhost:11434

# Session secret (required for the API server)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Ports (optional — these are the defaults used by start.sh and start.ps1)
API_PORT=8080
FRONT_PORT=3000

# Local PostgreSQL container defaults used by start.ps1 when Docker is present
NAGATHA_PG_CONTAINER=nagatha-postgres
NAGATHA_PG_VOLUME=nagatha-postgres-data
